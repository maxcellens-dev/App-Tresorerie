{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./app/*"] },
    "module": "esnext",
    // Honore le champ `exports` des packages (react-query, etc.) — sinon résolution
    // « node » héritée d'expo/tsconfig.base → types perdus → flot d'implicit-any.
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext", "dom"]
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "admin", ".expo", "dist", "build"]
}
