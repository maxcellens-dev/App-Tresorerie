{
  "expo": {
    "name": "Relyka",
    "slug": "tresorerie",
    "version": "1.0.0",
    "scheme": "tresorerie",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D2E2A"
      },
      "package": "com.relyka.myapp"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/favicon.png",
      "name": "Relyka",
      "shortName": "Relyka",
      "description": "Laissez-vous guider pour faire des économies.",
      "themeColor": "#020617",
      "backgroundColor": "#020617"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "204995de-9231-49da-a21d-68c4505ac85b"
      }
    }
  }
}
