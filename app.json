{
  "expo": {
    "name": "Relyka",
    "slug": "tresorerie",
    "version": "1.0.0",
    "scheme": "tresorerie",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D2E2A"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/favicon.png",
      "name": "Relyka",
      "shortName": "Relyka",
      "description": "Laissez-vous guider pour faire des économies.",
      "themeColor": "#020617",
      "backgroundColor": "#020617"
    }
  }
}
