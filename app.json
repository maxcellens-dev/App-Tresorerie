{
  "expo": {
    "name": "Relyka",
    "owner": "relykadevs-team",
    "slug": "relyka-app",
    "version": "1.0.3",
    "scheme": "relyka-app",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2E2A"
      },
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.relyka.myapp",
      "versionCode": 33
    },
    "plugins": [
      "./plugins/withJitpackAuth",
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 96,
          "resizeMode": "contain",
          "backgroundColor": "#F4EFE6"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/favicon.png",
      "name": "Relyka",
      "shortName": "Relyka",
      "description": "Laissez-vous guider pour faire des économies.",
      "themeColor": "#808F88",
      "backgroundColor": "#808F88"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fc209ff9-5d8b-4c7e-a83e-a3036f45930a"
      }
    },
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/fc209ff9-5d8b-4c7e-a83e-a3036f45930a",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 7000
    }
  }
}
